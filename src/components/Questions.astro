  function initQuestions() {
    const scene = document.getElementById('questions-scene');
    const card = document.getElementById('q-card');
    const titleEl = document.getElementById('q-title');
    const subtitleEl = document.getElementById('q-subtitle');
    const optionsEl = document.getElementById('q-options');
    const progressBar = document.getElementById('q-progress-bar');
    const progressText = document.getElementById('q-progress-text');
    const progressPct = document.getElementById('q-progress-pct');
    const multiContinue = document.getElementById('q-multi-continue');
    const multiBtn = document.getElementById('q-multi-btn') as HTMLButtonElement | null;

    if (!scene || !card || !titleEl || !subtitleEl || !optionsEl || !progressBar || !progressText || !progressPct) return;

    let currentIndex = 0;
    let questions: Question[] = [];
    const answers: Record<string, string> = {};
    // Multi-select state: set of selected values for current question
    let multiSelected: Set<string> = new Set();

    // ── Mood → genre incompatibilities ──────────────────────────────────────────
    // Genres that contradict the selected mood — hidden when that mood is chosen
    const MOOD_BLOCKED_GENRES: Record<string, string[]> = {
      // anime moods
      happy:       ['horror', 'mystery'],      // alegre → no terror/misterio
      energetic:   ['romance'],                // eufórico → no romance lento
      melancholic: ['comedy', 'sports'],       // melancólico → no comedia/deportes
      thoughtful:  ['sports'],                 // reflexivo → no deportes
      // movie moods
      romantic:    ['horror', 'thriller'],     // romántico → no terror/thriller
      excited:     ['documentary'],            // adrenalina → no documental
    };

    /** Disables genre options that contradict the already-answered mood */
    function applyMoodFilter(q: Question) {
      if (q.id !== 'genres') return;
      const mood = answers['mood'];
      if (!mood) return;
      const blocked = MOOD_BLOCKED_GENRES[mood] ?? [];
      if (!blocked.length) return;

      const allBtns = optionsEl!.querySelectorAll<HTMLButtonElement>('button.q-opt');
      let anyBlocked = false;
      allBtns.forEach(btn => {
        const val = btn.dataset.value ?? '';
        if (blocked.includes(val)) {
          btn.disabled = true;
          btn.style.opacity       = '0.18';
          btn.style.transform     = 'scale(0.95)';
          btn.style.filter        = 'grayscale(0.8)';
          btn.style.cursor        = 'not-allowed';
          btn.style.pointerEvents = 'none';
          anyBlocked = true;
        }
      });

      if (anyBlocked) {
        const noteEl = document.getElementById('q-conflict-note');
        if (noteEl) {
          noteEl.textContent = currentLang === 'es'
            ? '🚫 Algunos géneros no encajan con tu estado de ánimo y están desactivados'
            : "🚫 Some genres don't match your mood and are disabled";
          noteEl.style.display = 'block';
        }
      }
    }

    type QLang = 'en' | 'es';
    let currentLang: QLang = (localStorage.getItem('lang') || 'en') as QLang;
    function getProgressText(idx: number, total: number): string {
      return currentLang === 'es' ? `Pregunta ${idx + 1} de ${total}` : `Question ${idx + 1} of ${total}`;
    }

    function renderQuestion(index: number) {
      const q = questions[index];
      if (!q) return;

      multiSelected = new Set();

      const total = questions.length;
      const pct = Math.round((index / total) * 100);
      progressText!.textContent = getProgressText(index, total);
      progressPct!.textContent = `${pct}%`;
      progressBar!.style.width = `${pct}%`;

      titleEl!.textContent = q.title;
      subtitleEl!.textContent = q.subtitle;
      optionsEl!.innerHTML = '';

      // Adaptive grid columns based on option count
      const count = q.options.length;
      if (count <= 4) {
        optionsEl!.className = 'grid gap-3 grid-cols-1 sm:grid-cols-2';
      } else if (count <= 6) {
        optionsEl!.className = 'grid gap-3 grid-cols-2 sm:grid-cols-3';
      } else {
        optionsEl!.className = 'grid gap-3 grid-cols-2 sm:grid-cols-4';
      }

      // Multi-select continue button
      if (multiContinue) {
        multiContinue.style.display = q.multi ? 'flex' : 'none';
        if (multiBtn) {
          multiBtn.disabled = true;
          multiBtn.textContent = currentLang === 'es' ? 'Continuar →' : 'Continue →';
        }
      }

      q.options.forEach((opt, i) => {
        const btn = document.createElement('button');
        btn.dataset.value = opt.value;
        btn.dataset.conflictGroup = opt.conflictGroup ?? '';
        btn.className = `q-opt group flex flex-col items-center gap-2 p-4 rounded-xl 
                         bg-white/5 border border-white/10 
                         hover:border-cyber-purple/50 hover:bg-cyber-purple/10
                         transition-all duration-300 text-center cursor-pointer`;
        btn.innerHTML = `
          <span class="text-2xl sm:text-3xl">${opt.icon}</span>
          <span class="text-gray-300 group-hover:text-white transition-colors font-sans text-xs sm:text-sm leading-snug">${opt.label}</span>
        `;

        if (q.multi) {
          btn.addEventListener('click', () => toggleMultiOption(q.id, opt.value, btn));
        } else {
          btn.addEventListener('click', () => selectOption(q.id, opt.value, btn));
        }
        optionsEl!.appendChild(btn);
      });

      // Hide conflict note for new question
      const noteEl = document.getElementById('q-conflict-note');
      if (noteEl) noteEl.style.display = 'none';

      // Animar todos los botones a la vez, sin escalonado que deja los últimos en opacity:0
      gsap.from(optionsEl!.querySelectorAll('button'), {
        y: 16,
        opacity: 0,
        duration: 0.35,
        ease: 'power2.out',
      });

      // Apply mood-based genre filter AFTER animation so opacity doesn't get overridden
      setTimeout(() => applyMoodFilter(q), 370);
    }

    /** Blocks/unblocks option buttons based on conflict groups defined in the question. */
    function updateConflictStates(q: Question) {
      if (!q.exclusiveGroups?.length) return;

      // Which conflict groups are currently active (have ≥1 selected option)
      const activeGroups = new Set<string>();
      q.options.forEach(opt => {
        if (multiSelected.has(opt.value) && opt.conflictGroup) {
          activeGroups.add(opt.conflictGroup);
        }
      });

      // Which groups are blocked because they conflict with an active group
      const blockedGroups = new Set<string>();
      q.exclusiveGroups.forEach(groupSet => {
        const activeInSet = groupSet.filter(g => activeGroups.has(g));
        if (activeInSet.length > 0) {
          groupSet.forEach(g => {
            if (!activeGroups.has(g)) blockedGroups.add(g);
          });
        }
      });

      // Apply visual states to each option button
      const allBtns = optionsEl!.querySelectorAll<HTMLButtonElement>('button.q-opt');
      allBtns.forEach(btn => {
        const grp = btn.dataset.conflictGroup;
        const isSelected = multiSelected.has(btn.dataset.value ?? '');
        const isBlocked  = !!(grp && blockedGroups.has(grp));

        btn.disabled = isBlocked;
        if (isBlocked) {
          btn.style.opacity       = '0.2';
          btn.style.transform     = 'scale(0.95)';
          btn.style.filter        = 'grayscale(0.7)';
          btn.style.cursor        = 'not-allowed';
          btn.style.pointerEvents = 'none';
        } else if (!isSelected) {
          btn.style.opacity       = '1';
          btn.style.transform     = 'scale(1)';
          btn.style.filter        = '';
          btn.style.cursor        = 'pointer';
          btn.style.pointerEvents = '';
        }
      });

      // Show / hide the conflict warning note
      const noteEl = document.getElementById('q-conflict-note');
      if (noteEl) {
        if (blockedGroups.size > 0) {
          noteEl.textContent = currentLang === 'es'
            ? '⚠️ Géneros incompatibles bloqueados — alegre/relajado y terror/psicológico no se mezclan'
            : "⚠️ Incompatible genres blocked — light-hearted and horror/thriller don't mix";
          noteEl.style.display = 'block';
        } else {
          noteEl.style.display = 'none';
        }
      }
    }

    function toggleMultiOption(questionId: string, value: string, btnEl: HTMLElement) {
      if ((btnEl as HTMLButtonElement).disabled) return; // blocked by conflict

      if (multiSelected.has(value)) {
        multiSelected.delete(value);
        gsap.to(btnEl, { borderColor: 'rgba(255,255,255,0.1)', backgroundColor: 'rgba(255,255,255,0.05)', scale: 1, duration: 0.2 });
        btnEl.classList.remove('ring-2', 'ring-cyber-purple');
      } else {
        multiSelected.add(value);
        gsap.to(btnEl, { borderColor: 'rgba(176,38,255,0.7)', backgroundColor: 'rgba(176,38,255,0.12)', scale: 1.03, duration: 0.2 });
        btnEl.classList.add('ring-2', 'ring-cyber-purple');
      }
      if (multiBtn) {
        multiBtn.disabled = multiSelected.size === 0;
        multiBtn.textContent = multiSelected.size > 0
          ? currentLang === 'es'
            ? `Continuar con ${multiSelected.size} seleccionado${multiSelected.size > 1 ? 's' : ''} →`
            : `Continue with ${multiSelected.size} selected →`
          : currentLang === 'es' ? 'Continuar →' : 'Continue →';
      }
      // Update conflict blocking after every toggle
      const q = questions[currentIndex];
      if (q) updateConflictStates(q);
    }

    function commitMultiAndAdvance(questionId: string) {
      answers[questionId] = [...multiSelected].join(',');

      // Fill progress bar immediately on selection
      const total = questions.length;
      const nextPct = Math.round(((currentIndex + 1) / total) * 100);
      progressBar!.style.width = `${nextPct}%`;
      progressPct!.textContent = `${nextPct}%`;

      advanceQuestion();
    }

    multiBtn?.addEventListener('click', () => {
      const q = questions[currentIndex];
      if (q?.multi) commitMultiAndAdvance(q.id);
    });

    function selectOption(questionId: string, value: string, btnEl: HTMLElement) {
      answers[questionId] = value;

      // Fill progress bar immediately on selection
      const total = questions.length;
      const nextPct = Math.round(((currentIndex + 1) / total) * 100);
      progressBar!.style.width = `${nextPct}%`;
      progressPct!.textContent = `${nextPct}%`;

      const allBtns = optionsEl!.querySelectorAll('button');
      allBtns.forEach(b => {
        if (b !== btnEl) gsap.to(b, { opacity: 0.3, scale: 0.95, duration: 0.3 });
      });
      gsap.to(btnEl, { scale: 1.05, borderColor: 'rgba(176, 38, 255, 0.7)', duration: 0.3 });

      setTimeout(advanceQuestion, 500);
    }

    function advanceQuestion() {
      currentIndex++;
      if (currentIndex < questions.length) {
        gsap.to(card, {
          x: -30,
          opacity: 0,
          duration: 0.3,
          ease: 'power2.in',
          onComplete: () => {
            renderQuestion(currentIndex);
            gsap.fromTo(card, { x: 30, opacity: 0 }, { x: 0, opacity: 1, duration: 0.4, ease: 'power2.out' });
          },
        });
      } else {
        finishQuestions();
      }
    }

    function finishQuestions() {
      progressBar!.style.width = '100%';
      progressPct!.textContent = '100%';

      // Save answers
      localStorage.setItem('userAnswers', JSON.stringify(answers));

      gsap.to(scene, {
        opacity: 0,
        duration: 0.8,
        ease: 'power2.in',
        onComplete: () => {
          scene!.classList.add('scene-hidden');
          scene!.classList.remove('scene-visible');
          window.dispatchEvent(new CustomEvent('scene:advance', { detail: { from: 'questions', to: 'result' } }));
        },
      });
    }

    window.addEventListener('scene:advance', (e: Event) => {
      const detail = (e as CustomEvent).detail;
      if (detail.to !== 'questions') return;

      const choice = localStorage.getItem('pillChoice');
      currentLang = (localStorage.getItem('lang') || 'en') as QLang;
      questions = choice === 'anime'
        ? (currentLang === 'es' ? questionsAnime : questionsAnimeEN)
        : (currentLang === 'es' ? questionsMovie : questionsMovieEN);
      currentIndex = 0;
      // Reset answers from any previous run
      Object.keys(answers).forEach(k => delete answers[k]);

      scene.classList.remove('scene-hidden');
      scene.classList.add('scene-visible');

      // Kill any lingering GSAP tweens (e.g. opacity:0 left from finishQuestions)
      gsap.killTweensOf(scene);
      gsap.set(scene, { opacity: 0 });
      gsap.to(scene, { opacity: 1, duration: 0.5 });
      renderQuestion(0);
    });

    window.addEventListener('lang:change', (e: Event) => {
      currentLang = ((e as CustomEvent).detail.lang || 'en') as QLang;
      if (!scene!.classList.contains('scene-hidden')) {
        const choice = localStorage.getItem('pillChoice');
        questions = choice === 'anime'
          ? (currentLang === 'es' ? questionsAnime : questionsAnimeEN)
          : (currentLang === 'es' ? questionsMovie : questionsMovieEN);
        currentIndex = Math.min(currentIndex, questions.length - 1);
        renderQuestion(currentIndex);
      }
    });
  }

  document.addEventListener('astro:page-load', initQuestions);
  initQuestions();
</script>
