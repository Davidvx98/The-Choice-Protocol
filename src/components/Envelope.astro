---
/**
 * Intro scene — Sobre + Carta en una sola secuencia continua
 *
 * Fase 1: Sobre flotando con partículas, click para abrir
 * Fase 2: La tapa se abre, el sobre baja, la carta sube a centro
 * Fase 3: Typing effect, input nombre, Continuar → Pills
 */
---

<section id="intro-scene" class="scene scene-visible" aria-label="Introducción — Abrir el sobre">

  <!-- ╔══════════════════════════════════╗ -->
  <!-- ║  FASE 1: SOBRE                   ║ -->
  <!-- ╚══════════════════════════════════╝ -->

  <div id="envelope-stage" class="absolute inset-0 flex flex-col items-center justify-center">

    <!-- Hint + language toggle row -->
    <div id="envelope-hint-row" class="flex items-center gap-4 mb-8">
      <p id="envelope-hint"
         class="text-cyber-purple/60 text-xs sm:text-sm tracking-widest uppercase animate-pulse select-none">
        Haz click para abrir
      </p>
      <button id="lang-toggle"
        aria-label="Toggle language"
        class="flex items-center gap-1 px-2.5 py-1.5 rounded-xl
               bg-black/50 border border-white/10 backdrop-blur-md
               text-gray-400 text-xs font-mono
               hover:border-cyber-blue/60 hover:text-cyber-blue
               transition-all duration-300 cursor-pointer select-none">
        <span id="lang-flag" class="text-base leading-none xl:hidden">🇬🇧</span>
        <span id="lang-label" class="tracking-widest uppercase hidden sm:inline">EN</span>
      </button>
    </div>

    <!-- Envelope wrapper (es lo que flota) -->
    <div id="envelope-wrapper" class="relative">

      <div id="envelope"
           role="button" tabindex="0" aria-label="Abrir sobre"
           class="relative cursor-pointer select-none"
           style="perspective: 700px;">

        <!-- Cuerpo del sobre -->
        <div id="envelope-body"
             class="w-72 h-48 sm:w-96 sm:h-56 bg-gradient-to-br from-purple-950/60 to-indigo-950/60
                    border border-cyber-purple/30 rounded-lg relative overflow-visible
                    transition-all duration-300 hover:border-cyber-purple/50"
             style="box-shadow: 0 0 30px rgba(176,38,255,0.15);">

          <!-- Cara inferior (triángulo apuntando arriba) -->
          <div class="absolute bottom-0 left-0 w-full h-1/2 pointer-events-none"
               style="clip-path: polygon(0 100%, 50% 0%, 100% 100%);
                      background: linear-gradient(to top, rgba(88,28,135,0.35), rgba(67,20,105,0.15));">
          </div>

          <!-- Tapa / flap (triángulo desde arriba) -->
          <div id="envelope-flap"
               class="absolute top-0 left-0 w-full origin-top"
               style="height: 54%; transform-style: preserve-3d; z-index: 10;">
            <div class="w-full h-full pointer-events-none"
                 style="clip-path: polygon(0 0, 50% 100%, 100% 0);
                        background: linear-gradient(to bottom, rgba(109,40,217,0.55), rgba(79,26,163,0.3));
                        border-bottom: 1px solid rgba(176,38,255,0.2);">
            </div>
          </div>

          <!-- Sello de lacre -->
          <div id="wax-seal"
               class="absolute z-20 w-14 h-14 rounded-full
                      bg-white
                      border-2 border-white/80
                      flex items-center justify-center select-none"
               style="top: 50%; left: 50%; transform: translate(-50%, -50%);
                      box-shadow: 0 0 18px rgba(255,255,255,0.5), 0 0 40px rgba(255,255,255,0.15);">
            <span class="text-2xl">💊</span>
          </div>

          <!-- Líneas decorativas -->
          <div class="absolute bottom-5 left-6 right-6 space-y-1.5 opacity-25 pointer-events-none">
            <div class="h-px bg-cyber-purple rounded"></div>
            <div class="h-px bg-cyber-purple rounded w-4/5"></div>
            <div class="h-px bg-cyber-purple rounded w-3/5"></div>
          </div>
        </div><!-- /envelope-body -->

        <!-- Sombra -->
        <div class="w-56 h-3 mx-auto mt-1 bg-cyber-purple/10 rounded-full blur-xl pointer-events-none"></div>
      </div><!-- /envelope -->
    </div><!-- /envelope-wrapper -->

    <!-- Partículas ambientales -->
    <div id="envelope-particles" class="absolute inset-0 pointer-events-none overflow-hidden"></div>
  </div><!-- /envelope-stage -->


  <!-- ╔══════════════════════════════════╗ -->
  <!-- ║  FASE 2: CARTA                   ║ -->
  <!-- ╚══════════════════════════════════╝ -->

  <div id="letter-stage"
       class="absolute inset-0 flex items-center justify-center px-4"
       style="opacity: 0; pointer-events: none;">

    <div id="letter-card"
         class="bg-gradient-to-br from-purple-950/60 to-indigo-950/60 border border-cyber-purple/20
                max-w-lg w-full p-8 sm:p-10 relative overflow-hidden rounded-2xl"
         style="box-shadow: 0 0 60px rgba(176,38,255,0.12), 0 0 0 1px rgba(176,38,255,0.06);">

      <!-- Decoraciones de esquina -->
      <div class="absolute top-0 left-0 w-14 h-14 border-t-2 border-l-2 border-cyber-purple/20 rounded-tl-2xl pointer-events-none"></div>
      <div class="absolute bottom-0 right-0 w-14 h-14 border-b-2 border-r-2 border-cyber-purple/20 rounded-br-2xl pointer-events-none"></div>
      <!-- Línea superior decorativa -->
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-2/3 h-px bg-gradient-to-r from-transparent via-cyber-purple/25 to-transparent pointer-events-none"></div>

      <div class="relative z-10 space-y-6">

        <!-- Texto typing -->
        <div class="min-h-[110px]">
          <p id="letter-text" class="text-gray-300 text-sm sm:text-base leading-relaxed font-mono"></p>
          <span id="letter-cursor" class="typing-cursor text-cyber-purple hidden">█</span>
        </div>

        <!-- Nombre (oculto hasta que termine el typing) -->
        <div id="name-section" class="space-y-3" style="opacity: 0; pointer-events: none;">
          <label for="user-name"
                 class="block text-cyber-purple/80 text-xs tracking-widest uppercase font-mono">
            ¿Cómo te llamas, viajero?
          </label>
          <input type="text"
                 id="user-name"
                 maxlength="30"
                 autocomplete="off"
                 spellcheck="false"
                 placeholder="Tu nombre..."
                 class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3
                        text-white font-mono text-sm placeholder:text-gray-600
                        focus:outline-none focus:border-cyber-purple/70
                        focus:shadow-[0_0_12px_rgba(176,38,255,0.25)]
                        transition-all duration-300" />
        </div>

        <!-- Botón Continuar -->
        <div id="continuar-section" class="flex justify-end" style="opacity: 0; pointer-events: none;">
          <button id="continuar-btn"
                  class="btn-cyber text-cyber-purple disabled:opacity-30 disabled:cursor-not-allowed"
                  disabled>
            Continuar &nbsp;→
          </button>
        </div>

      </div>
    </div><!-- /letter-card -->
  </div><!-- /letter-stage -->

</section><!-- /intro-scene -->


<script>
  import { gsap } from 'gsap';

  function initIntro() {
    const scene         = document.getElementById('intro-scene');
    const envStage      = document.getElementById('envelope-stage');
    const letterStage   = document.getElementById('letter-stage');
    const letterCard    = document.getElementById('letter-card');
    const envelope      = document.getElementById('envelope');
    const flap          = document.getElementById('envelope-flap');
    const seal          = document.getElementById('wax-seal');
    const hint          = document.getElementById('envelope-hint');
    const particles     = document.getElementById('envelope-particles');
    const letterText    = document.getElementById('letter-text');
    const letterCursor  = document.getElementById('letter-cursor');
    const nameSection   = document.getElementById('name-section');
    const nameInput     = document.getElementById('user-name') as HTMLInputElement | null;
    const continuarSec  = document.getElementById('continuar-section');
    const continuarBtn  = document.getElementById('continuar-btn') as HTMLButtonElement | null;

    if (!scene || !envelope || !flap || !seal || !envStage ||
        !letterStage || !letterCard || !letterText || !letterCursor ||
        !nameSection || !nameInput || !continuarSec || !continuarBtn) return;

    type Lang = 'en' | 'es';
    const INTRO_STRINGS: Record<Lang, { hint: string; letterContent: string; nameLabel: string; namePlaceholder: string; continuar: string; }> = {
      es: {
        hint: 'Haz click para abrir',
        letterContent: [
          'Te estaba esperando...',
          '',
          'No has llegado aquí por casualidad.',
          'Algo o alguien te ha traído hasta este umbral.',
          '',
          'Lo que está a punto de revelarse no es para todos.',
          'Solo aquellos que se atreven a elegir',
          'descubren lo que realmente buscan.',
          '',
          'Antes de continuar... necesito saber tu nombre.',
          'Los secretos no se comparten con desconocidos.',
        ].join('\n'),
        nameLabel: '¿Cómo te llamas, viajero?',
        namePlaceholder: 'Tu nombre...',
        continuar: 'Continuar &nbsp;→',
      },
      en: {
        hint: 'Click to open',
        letterContent: [
          'I have been waiting for you...',
          '',
          "You didn't arrive here by chance.",
          'Something — or someone — brought you to this threshold.',
          '',
          'What is about to be revealed is not for everyone.',
          'Only those who dare to choose',
          'discover what they truly seek.',
          '',
          'Before we continue... I need to know your name.',
          'Secrets are not shared with strangers.',
        ].join('\n'),
        nameLabel: "What's your name, traveler?",
        namePlaceholder: 'Your name...',
        continuar: 'Continue &nbsp;→',
      },
    };

    function getIntroLang(): Lang { return (localStorage.getItem('lang') || 'en') as Lang; }
    function applyIntroLang(lang: Lang) {
      const s = INTRO_STRINGS[lang];
      if (hint) hint.textContent = s.hint;
      const nameLabel = document.querySelector<HTMLElement>('label[for="user-name"]');
      if (nameLabel) nameLabel.textContent = s.nameLabel;
      if (nameInput) nameInput.placeholder = s.namePlaceholder;
      if (continuarBtn) continuarBtn.innerHTML = s.continuar;
    }

    // ── Audio carta ──────────────────────────────────────────────────────
    let letterAudio: HTMLAudioElement | null = null;

    function playLetterAudio() {
      letterAudio = new Audio('/media/lectura_carta.mp3');
      letterAudio.play().catch(() => {});
    }

    function stopLetterAudio() {
      if (letterAudio) {
        letterAudio.pause();
        letterAudio.currentTime = 0;
        letterAudio = null;
      }
    }

    // Stop audio on any scene transition away from intro
    window.addEventListener('scene:advance', (e: Event) => {
      const detail = (e as CustomEvent).detail;
      if (detail.from === 'intro') stopLetterAudio();
    });

    // ── Float del sobre ──────────────────────────────────────────────────
    const floatAnim = gsap.to('#envelope-wrapper', {
      y: -10,
      duration: 2.2,
      ease: 'sine.inOut',
      yoyo: true,
      repeat: -1,
    });

    // ── Partículas ───────────────────────────────────────────────────────
    if (particles) {
      for (let i = 0; i < 18; i++) {
        const p = document.createElement('div');
        p.className = 'particle';
        p.style.left = `${Math.random() * 100}%`;
        p.style.top  = `${Math.random() * 100}%`;
        particles.appendChild(p);
        gsap.to(p, {
          y: -(window.innerHeight + 50),
          x: (Math.random() - 0.5) * 160,
          opacity: 0,
          duration: 3.5 + Math.random() * 4,
          repeat: -1,
          delay: Math.random() * 4,
          ease: 'none',
        });
      }
    }

    // ── Typing ───────────────────────────────────────────────────────────
    function typeText(text: string, el: HTMLElement, speed = 38): Promise<void> {
      return new Promise(resolve => {
        let i = 0;
        el.innerHTML = '';
        letterCursor!.classList.remove('hidden');
        const iv = setInterval(() => {
          if (i < text.length) {
            if (text[i] === '\n') {
              el.appendChild(document.createElement('br'));
            } else {
              const last = el.lastChild;
              if (last && last.nodeType === Node.TEXT_NODE) {
                last.textContent += text[i];
              } else {
                el.appendChild(document.createTextNode(text[i]));
              }
            }
            i++;
          } else {
            clearInterval(iv);
            letterCursor!.classList.add('hidden');
            resolve();
          }
        }, speed);
      });
    }

    // ── Apertura del sobre ───────────────────────────────────────────────
    let opened = false;

    async function openEnvelope() {
      if (opened) return;
      opened = true;

      // Ocultar el hint inmediatamente para mejorar la inmersión
      if (hint) { hint.style.opacity = '0'; hint.style.pointerEvents = 'none'; }
      const hintRow = document.getElementById('envelope-hint-row');
      if (hintRow) { hintRow.style.opacity = '0'; hintRow.style.pointerEvents = 'none'; }

      // Pantalla completa e inicio de música
      document.documentElement.requestFullscreen().catch(() => {});
      window.dispatchEvent(new CustomEvent('envelope:opened'));

      floatAnim.kill();
      gsap.set('#envelope-wrapper', { y: 0 });

      // Preparar la carta para que GSAP la pueda animar
      gsap.set(letterCard, { y: 40, scale: 0.95, opacity: 0 });

      const tl = gsap.timeline();

      // 1) Hint row desaparece
      tl.to('#envelope-hint-row', { opacity: 0, duration: 0.2 });

      // 2) Sello se rompe
      tl.to(seal, { scale: 1.6, opacity: 0, duration: 0.38, ease: 'back.in(2)' });

      // 3) Tapa se levanta
      tl.to(flap, { rotateX: -175, duration: 0.85, ease: 'power2.inOut' }, '-=0.15');

      // 4) Brillo del sobre
      tl.to('#envelope-body', {
        boxShadow: '0 0 55px rgba(176,38,255,0.55), 0 0 100px rgba(176,38,255,0.2)',
        borderColor: 'rgba(176,38,255,0.65)',
        duration: 0.45,
      }, '-=0.5');

      // 5) Sobre baja con fade
      tl.to(envStage, { y: 90, opacity: 0, duration: 0.55, ease: 'power2.in' }, '+=0.2');

      // 6) Carta aparece desde abajo
      tl.to(letterStage, { opacity: 1, pointerEvents: 'auto', duration: 0.01 });
      tl.to(letterCard, { y: 0, scale: 1, opacity: 1, duration: 0.7, ease: 'power3.out' }, '-=0.01');

      // 7) Ocultar sobre del DOM
      tl.set(envStage, { display: 'none' });

      // 8) Typing
      tl.call(() => {
        playLetterAudio();
        const returning = !!localStorage.getItem('introDone');
        void (async () => {
          await new Promise(r => setTimeout(r, returning ? 0 : 120));
          await typeText(INTRO_STRINGS[getIntroLang()].letterContent, letterText!, returning ? 2 : 85);
          // Mostrar input de nombre
          await new Promise(r => setTimeout(r, returning ? 0 : 320));
          gsap.to(nameSection, {
            opacity: 1, duration: 0.55, ease: 'power2.out',
            onComplete: () => {
              nameSection!.style.pointerEvents = 'auto';
              nameInput!.focus();
            },
          });
        })();
      });
    }

    envelope.addEventListener('click', openEnvelope);
    envelope.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openEnvelope(); }
    });

    // ── Input de nombre ──────────────────────────────────────────────────
    nameInput.addEventListener('input', () => {
      const hasName = nameInput!.value.trim().length > 0;
      continuarBtn!.disabled = !hasName;
      gsap.to(continuarSec, {
        opacity: hasName ? 1 : 0,
        duration: 0.35,
        onStart:    () => { if (hasName) continuarSec!.style.pointerEvents = 'auto'; },
        onComplete: () => { if (!hasName) continuarSec!.style.pointerEvents = 'none'; },
      });
    });

    // ── Continuar → Pills ────────────────────────────────────────────────
    function goToPills() {
      const name = nameInput!.value.trim();
      if (!name || continuarBtn!.disabled) return;
      stopLetterAudio();
      localStorage.setItem('userName', name);
      localStorage.setItem('introDone', '1');

      gsap.to(scene, {
        opacity: 0, scale: 0.97, duration: 0.7, ease: 'power2.in',
        onComplete: () => {
          scene!.classList.add('scene-hidden');
          scene!.classList.remove('scene-visible');
          window.dispatchEvent(new CustomEvent('scene:advance', {
            detail: { from: 'intro', to: 'message' },
          }));
        },
      });
    }

    continuarBtn.addEventListener('click', goToPills);
    nameInput.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter') goToPills();
    });

    // Apply initial lang + listen for changes
    applyIntroLang(getIntroLang());
    window.addEventListener('lang:change', (e: Event) => {
      applyIntroLang(((e as CustomEvent).detail.lang || 'en') as Lang);
    });
  }

  document.addEventListener('astro:page-load', initIntro);
  initIntro();
</script>


<style>
  /* La carta arranca invisible para que GSAP la anime */
  #letter-card {
    opacity: 0;
  }
</style>
