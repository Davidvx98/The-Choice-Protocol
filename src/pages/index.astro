---
/**
 * Index page - Orquesta todas las escenas del flujo narrativo
 * Intro (Sobre + Carta) → Pills → Questions → Result
 */
import Layout from '../layouts/Layout.astro';
import Envelope from '../components/Envelope.astro';
import Letter from '../components/Letter.astro';
import Pills from '../components/Pills.astro';
import Questions from '../components/Questions.astro';
import Result from '../components/Result.astro';
---

<Layout>
  <main class="relative w-full h-screen overflow-hidden" role="main">
    <!-- SEO: Contenido visible para crawlers que no ejecutan JS -->
    <header class="sr-only">
      <h1>Las Píldoras — Recomendador de Anime y Películas con Inteligencia Artificial</h1>
      <p>Descubre qué anime o película ver hoy. Elige tu camino, responde preguntas sobre tu estado de ánimo y preferencias, y recibe 3 recomendaciones personalizadas generadas por IA.</p>
    </header>

    <!-- SEO: Contenido indexable oculto visualmente pero accesible para bots -->
    <article class="sr-only">
      <h2>¿Qué anime ver hoy? Recomendaciones personalizadas con IA</h2>
      <p>Las Píldoras es un recomendador interactivo que usa Google Gemini para sugerirte anime y películas según tu estado de ánimo. Funciona como una experiencia narrativa: abres un sobre misterioso, eliges entre la Píldora Roja (anime) o la Píldora Azul (películas), respondes preguntas sobre tus gustos y recibes 3 recomendaciones perfectas.</p>
      <h3>Tipos de recomendaciones</h3>
      <ul>
        <li>Recomendaciones de anime: acción, romance, misterio, comedia, ciencia ficción, fantasía, terror, deportes</li>
        <li>Recomendaciones de películas: acción, drama, terror, comedia, ciencia ficción, thriller, animación, documentales</li>
      </ul>
      <h3>¿Cómo funciona el recomendador?</h3>
      <ol>
        <li>Abre el sobre misterioso y descubre el mensaje</li>
        <li>Elige tu camino: Píldora Roja (anime) o Píldora Azul (películas)</li>
        <li>Responde preguntas sobre tu estado de ánimo, géneros favoritos y preferencias</li>
        <li>Recibe 3 recomendaciones personalizadas generadas por inteligencia artificial</li>
      </ol>
      <h3>Géneros disponibles</h3>
      <p>Anime: Shonen, Seinen, Shojo, Slice of Life, Mecha, Isekai, Romance, Acción, Aventura, Misterio, Psicológico, Terror, Comedia, Deportes, Fantasía, Ciencia Ficción.</p>
      <p>Películas: Acción, Aventura, Drama, Romance, Terror, Suspense, Comedia, Ciencia Ficción, Thriller, Crimen, Animación, Documental.</p>
    </article>

    <!-- Todas las escenas se apilan en posición absoluta -->
    <Envelope />
    <Letter />
    <Pills />
    <Questions />
    <Result />

    <!-- ⚙️ Settings badge — bottom-left -->
    <div id="settings-badge-wrap" class="fixed bottom-4 left-4 z-50">
      <!-- The glowing badge -->
      <button id="settings-badge"
        aria-label="Configuración"
        class="relative flex items-center gap-2 px-3 py-2 rounded-xl
               bg-black/60 border border-white/10 backdrop-blur-md
               text-gray-400 text-xs font-mono
               hover:border-cyber-purple/60 hover:text-cyber-purple
               transition-all duration-300 cursor-pointer select-none">
        <span id="settings-badge-icon" class="text-base leading-none">⚙️</span>
        <span id="settings-badge-label" class="tracking-widest uppercase hidden sm:inline">Config</span>
        <!-- Pulse ring — animated by JS -->
        <span id="settings-pulse"
          class="absolute -inset-1 rounded-xl border border-cyber-purple/50 opacity-0 pointer-events-none"></span>
      </button>

      <!-- Expanded panel — toggled by click -->
      <div id="settings-panel"
        class="absolute bottom-full left-0 mb-3 w-64
               glass rounded-2xl px-5 py-4 flex-col gap-4
               hidden">

        <!-- Header -->
        <p class="text-cyber-purple text-xs font-mono tracking-widest uppercase border-b border-white/5 pb-2"
           id="cfg-title">Configuración</p>

        <!-- Volume -->
        <div class="flex flex-col gap-1.5">
          <div class="flex items-center justify-between">
            <label for="settings-vol" class="text-gray-400 text-xs font-mono flex items-center gap-1.5">
              🔊 <span id="cfg-vol-label">Music volume</span>
            </label>
            <span id="settings-vol-pct" class="text-cyber-purple text-xs font-mono">10%</span>
          </div>
          <input id="settings-vol" type="range" min="0" max="1" step="0.05" value="0.10"
            class="w-full accent-cyber-purple cursor-pointer h-1" aria-label="Volume" />
        </div>

        <!-- Skip animations -->
        <div class="flex flex-col gap-1">
          <div class="flex items-center justify-between">
            <p class="text-gray-400 text-xs font-mono flex items-center gap-1.5">⚡ <span id="cfg-skip-title">Skip animations</span></p>
            <button id="settings-skip-toggle"
              role="switch" aria-checked="false"
              class="relative w-10 h-5 rounded-full transition-colors duration-300 flex-shrink-0 focus:outline-none"
              style="background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.12);">
              <span id="settings-skip-thumb"
                class="absolute top-0.5 left-0.5 w-4 h-4 rounded-full transition-all duration-200"
                style="background:#6b7280;"></span>
            </button>
          </div>
          <p id="cfg-skip-desc" class="text-gray-600 text-xs leading-snug">Go directly to pill choice. Default name: Viajero.</p>
          <!-- Sub-option: disable particles/matrix rain for low-end devices -->
          <div id="skip-fx-row" class="flex items-center justify-between pl-3 border-l border-white/10" style="display:none;">
            <p class="text-gray-500 text-xs font-mono flex items-center gap-1.5">✨ <span id="cfg-skip-fx-label">Sin efectos visuales</span></p>
            <button id="settings-skipfx-toggle"
              role="switch" aria-checked="false"
              class="relative w-8 h-4 rounded-full transition-colors duration-300 flex-shrink-0 focus:outline-none"
              style="background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.12);">
              <span id="settings-skipfx-thumb"
                class="absolute top-0.5 left-0.5 w-3 h-3 rounded-full transition-all duration-200"
                style="background:#6b7280;"></span>
            </button>
          </div>
        </div>

        <!-- Reset experience -->
        <div class="flex flex-col gap-1">
          <p class="text-gray-400 text-xs font-mono flex items-center gap-1.5">🔄 <span id="cfg-reset-title">Reset experience</span></p>
          <p id="cfg-reset-desc" class="text-gray-600 text-xs leading-snug">Clears name, choice and answers. Returns to start.</p>
          <button id="settings-reset"
            class="mt-1 btn-cyber text-red-400 text-xs py-2">
            <span id="cfg-reset-btn">Reset</span>
          </button>
        </div>

        <!-- History -->
        <div class="flex flex-col gap-1">
          <p class="text-gray-400 text-xs font-mono flex items-center gap-1.5">📋 <span id="cfg-hist-title">Session history</span></p>
          <p id="cfg-hist-desc" class="text-gray-600 text-xs leading-snug">Review your saved recommendations.</p>
          <button id="settings-history"
            class="mt-1 btn-cyber text-cyber-blue text-xs py-2">
            <span id="cfg-hist-btn">View history</span>
          </button>
        </div>
      </div>
    </div>

    <!-- ⚖️ Legal notice — bottom-right (opposite to settings) -->
    <div id="legal-badge" class="fixed bottom-4 right-4 z-50">
      <button id="legal-badge-btn"
        aria-label="Aviso Legal"
        class="relative flex items-center gap-2 px-3 py-2 rounded-xl
               bg-black/60 border border-white/10 backdrop-blur-md
               text-gray-400 text-xs font-mono
               hover:border-cyber-blue/60 hover:text-cyber-blue
               transition-all duration-300 cursor-pointer select-none">
        <span class="text-base leading-none">⚖️</span>
        <span id="legal-badge-label" class="tracking-widest uppercase hidden sm:inline">Legal</span>
      </button>

      <!-- Legal panel — opens above the button -->
      <div id="legal-panel"
        class="absolute bottom-full right-0 mb-3 w-72
               glass rounded-2xl px-5 py-4 flex-col gap-3
               hidden">
        <p id="legal-panel-title" class="text-cyber-blue text-xs font-mono tracking-widest uppercase border-b border-white/5 pb-2">Aviso Legal</p>
        <p id="legal-panel-body" class="text-gray-400 text-xs leading-relaxed">
          Las Píldoras es un proyecto de código abierto creado con fines demostrativos.
          Las recomendaciones son generadas por IA y no sustituyen criterio profesional.
          Las imágenes provienen de APIs públicas (MyAnimeList, TMDB).
        </p>
        <div class="flex flex-col gap-1 pt-1">
          <a id="legal-cookies-link" href="/politica-cookies"
            class="text-cyber-blue text-xs font-mono hover:underline underline-offset-2 transition">
            🍪 <span id="legal-cookies-label">Política de Cookies</span>
          </a>
          <a id="legal-terms-link" href="/terminos"
            class="text-cyber-blue text-xs font-mono hover:underline underline-offset-2 transition">
            📄 <span id="legal-terms-label">Términos de Uso</span>
          </a>
        </div>
        <p id="legal-copy" class="text-gray-600 text-xs">© 2025 Las Píldoras — Open Source</p>
      </div>
    </div>

    <!-- 🍪 Cookie consent banner -->
    <div id="cookie-banner"
      class="fixed bottom-16 left-1/2 -translate-x-1/2 z-[60] w-[92%] max-w-xl
             glass rounded-2xl px-5 py-4 flex-col sm:flex-row items-center gap-3
             border border-white/10 shadow-xl"
      style="display:none">
      <span class="text-2xl flex-shrink-0">🍪</span>
      <p id="cookie-banner-text" class="text-gray-300 text-xs leading-relaxed text-center sm:text-left flex-1">
        Usamos cookies analíticas (Google Analytics) para mejorar la experiencia. No se almacena información personal.
      </p>
      <div class="flex gap-2 flex-shrink-0">
        <button id="cookie-reject"
          class="px-3 py-1.5 rounded-lg border border-white/10 text-gray-400 text-xs font-mono
                 hover:border-white/30 hover:text-white transition-all duration-200">
          <span id="cookie-reject-label">Rechazar</span>
        </button>
        <button id="cookie-accept"
          class="px-3 py-1.5 rounded-lg bg-cyber-purple/80 text-white text-xs font-mono
                 hover:bg-cyber-purple transition-all duration-200">
          <span id="cookie-accept-label">Aceptar</span>
        </button>
      </div>
    </div>

  </main>

  <!-- SEO Footer: Internal linking + structured navigation -->
  <footer class="sr-only">
    <nav aria-label="Navegación principal">
      <h2>Explorar Las Píldoras</h2>
      <ul>
        <li><a href="/">Inicio — Recomendador de Anime y Películas</a></li>
        <li><a href="/recomendaciones/anime">Recomendaciones de Anime con IA</a></li>
        <li><a href="/recomendaciones/peliculas">Recomendaciones de Películas con IA</a></li>
      </ul>
    </nav>
    <div>
      <h2>Sobre Las Píldoras</h2>
      <p>Las Píldoras (The Choice Protocol) es un recomendador gratuito de anime y películas impulsado por inteligencia artificial. Utiliza Google Gemini para analizar tus preferencias y estado de ánimo, generando recomendaciones personalizadas de entre miles de títulos.</p>
      <p>Géneros de anime disponibles: Acción, Romance, Misterio, Comedia, Ciencia Ficción, Fantasía, Terror, Deportes, Slice of Life, Isekai, Mecha, Psicológico.</p>
      <p>Géneros de películas disponibles: Acción, Aventura, Drama, Romance, Terror, Suspense, Comedia, Ciencia Ficción, Thriller, Crimen, Animación, Documental.</p>
      <p>&copy; 2025 Las Píldoras — The Choice Protocol. Proyecto open source.</p>
      <nav aria-label="Legal">
        <a href="/politica-cookies">Política de Cookies</a> ·
        <a href="/terminos">Términos y Condiciones</a> ·
        <a href="/aviso-legal">Aviso Legal</a>
      </nav>
    </div>
  </footer>
</Layout>

<script>
  // ── Scene debug ────────────────────────────────────────────────────────────
  window.addEventListener('scene:advance', (e: Event) => {
    const detail = (e as CustomEvent).detail;
    console.log(`[Scene] ${detail.from} → ${detail.to}`);
  });

  // ── Settings panel ─────────────────────────────────────────────────────────
  const settingsVol    = document.getElementById('settings-vol')     as HTMLInputElement | null;
  const settingsVolPct = document.getElementById('settings-vol-pct') as HTMLElement | null;
  const settingsPulse  = document.getElementById('settings-pulse')   as HTMLElement | null;
  const settingsPanel  = document.getElementById('settings-panel')   as HTMLElement | null;
  const settingsBadge  = document.getElementById('settings-badge')   as HTMLElement | null;

  let settingsOpen = false;
  settingsBadge?.addEventListener('click', (e) => {
    e.stopPropagation();
    settingsOpen = !settingsOpen;
    if (settingsPanel) {
      settingsPanel.classList.toggle('hidden', !settingsOpen);
      settingsPanel.classList.toggle('flex', settingsOpen);
    }
    if (settingsBadge) settingsBadge.style.color = settingsOpen ? 'var(--color-cyber-purple, #b026ff)' : '';
  });
  // Close panel when clicking outside
  document.addEventListener('click', (e) => {
    if (settingsOpen && !document.getElementById('settings-badge-wrap')?.contains(e.target as Node)) {
      settingsOpen = false;
      settingsPanel?.classList.add('hidden');
      settingsPanel?.classList.remove('flex');
      if (settingsBadge) settingsBadge.style.color = '';
    }
  });

  // Sync settings volume → audio players
  settingsVol?.addEventListener('input', () => {
    const v = parseFloat(settingsVol.value);
    if (settingsVolPct) settingsVolPct.textContent = `${Math.round(v * 100)}%`;
    Object.values(audioPlayers).forEach(({ audio }) => {
      if (!audio.paused) audio.volume = v;
    });
  });

  document.getElementById('settings-reset')?.addEventListener('click', () => {
    // Clear all user-session data (including introDone so typing is slow again)
    ['userName', 'pillChoice', 'userAnswers', 'introDone'].forEach(k => localStorage.removeItem(k));
    window.location.reload();
  });

  document.getElementById('settings-history')?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('history:open'));
  });

  // ── Skip animations toggle ─────────────────────────────────────────────────
  const skipToggleBtn   = document.getElementById('settings-skip-toggle') as HTMLElement | null;
  const skipThumb       = document.getElementById('settings-skip-thumb')  as HTMLElement | null;
  function getDefaultName() {
    return getLang() === 'es' ? 'Viajero' : 'Traveler';
  }

  function setSkipUI(on: boolean) {
    if (!skipToggleBtn || !skipThumb) return;
    skipToggleBtn.setAttribute('aria-checked', String(on));
    skipToggleBtn.style.background = on ? 'rgba(176,38,255,0.6)' : 'rgba(255,255,255,0.08)';
    skipToggleBtn.style.borderColor = on ? 'rgba(176,38,255,0.8)' : 'rgba(255,255,255,0.12)';
    skipThumb.style.background  = on ? '#fff' : '#6b7280';
    skipThumb.style.transform   = on ? 'translateX(20px)' : 'translateX(0)';
    // Show/hide the particles sub-option
    const skipFxRow = document.getElementById('skip-fx-row');
    if (skipFxRow) skipFxRow.style.display = on ? 'flex' : 'none';
  }

  function doSkipToPills() {
    if (!localStorage.getItem('userName')) {
      localStorage.setItem('userName', getDefaultName());
    }
    const introScene = document.getElementById('intro-scene');
    if (introScene) {
      introScene.classList.remove('scene-visible');
      introScene.classList.add('scene-hidden');
    }
    window.dispatchEvent(new CustomEvent('envelope:opened'));
    window.dispatchEvent(new CustomEvent('scene:advance', { detail: { from: 'intro', to: 'pills' } }));
    // Close the settings panel after skip
    settingsOpen = false;
    settingsPanel?.classList.add('hidden');
    settingsPanel?.classList.remove('flex');
    if (settingsBadge) settingsBadge.style.color = '';
  }

  // Init toggle visual from saved state
  const skipEnabled = localStorage.getItem('skipAnimations') === '1';
  setSkipUI(skipEnabled);

  skipToggleBtn?.addEventListener('click', () => {
    const nowOn = skipToggleBtn.getAttribute('aria-checked') !== 'true';
    setSkipUI(nowOn);
    if (nowOn) {
      localStorage.setItem('skipAnimations', '1');
      // Immediately skip if still on intro
      const introScene = document.getElementById('intro-scene');
      if (introScene?.classList.contains('scene-visible')) {
        doSkipToPills();
      }
    } else {
      localStorage.removeItem('skipAnimations');
    }
  });

  // Auto-skip on page load if flag is set
  if (localStorage.getItem('skipAnimations') === '1') {
    setTimeout(doSkipToPills, 50);
  }

  // ── Particles/effects sub-option ──────────────────────────────────────────
  const skipFxToggleBtn = document.getElementById('settings-skipfx-toggle') as HTMLElement | null;
  const skipFxThumb     = document.getElementById('settings-skipfx-thumb')  as HTMLElement | null;
  function setSkipFxUI(on: boolean) {
    if (!skipFxToggleBtn || !skipFxThumb) return;
    skipFxToggleBtn.setAttribute('aria-checked', String(on));
    skipFxToggleBtn.style.background  = on ? 'rgba(176,38,255,0.5)' : 'rgba(255,255,255,0.08)';
    skipFxToggleBtn.style.borderColor = on ? 'rgba(176,38,255,0.7)' : 'rgba(255,255,255,0.12)';
    skipFxThumb.style.background = on ? '#fff' : '#6b7280';
    skipFxThumb.style.transform  = on ? 'translateX(16px)' : 'translateX(0)';
  }
  setSkipFxUI(localStorage.getItem('skipParticles') === '1');
  skipFxToggleBtn?.addEventListener('click', () => {
    const nowOn = skipFxToggleBtn.getAttribute('aria-checked') !== 'true';
    setSkipFxUI(nowOn);
    nowOn ? localStorage.setItem('skipParticles', '1') : localStorage.removeItem('skipParticles');
  });

  // Periodic pulse glow on the settings badge
  function pulseBadge() {
    if (!settingsPulse) return;
    settingsPulse.style.transition = 'opacity 0.4s ease';
    settingsPulse.style.opacity = '1';
    setTimeout(() => { settingsPulse.style.opacity = '0'; }, 600);
  }
  setInterval(pulseBadge, 5000); // pulse every 5 s
  setTimeout(pulseBadge, 1500);  // first pulse on load

  // ── i18n (used for settings labels) ────────────────────────────────────────
  import { t as _t, getLang } from '../i18n/index.ts';
  const currentLang = getLang();

  // ── Apply settings panel strings from central i18n ──────────────────────
  function setCfgText(id: string, text: string) {
    const el = document.getElementById(id);
    if (el) el.textContent = text;
  }
  setCfgText('cfg-title',       _t(currentLang, 'settings.title'));
  setCfgText('cfg-vol-label',   _t(currentLang, 'settings.volLabel'));
  setCfgText('cfg-skip-title',  _t(currentLang, 'settings.skipTitle'));
  setCfgText('cfg-skip-desc',   _t(currentLang, 'settings.skipDesc'));
  setCfgText('cfg-reset-title', _t(currentLang, 'settings.resetTitle'));
  setCfgText('cfg-reset-desc',  _t(currentLang, 'settings.resetDesc'));
  setCfgText('cfg-reset-btn',   _t(currentLang, 'settings.resetBtn'));
  setCfgText('cfg-hist-title',  _t(currentLang, 'settings.histTitle'));
  setCfgText('cfg-hist-desc',   _t(currentLang, 'settings.histDesc'));
  setCfgText('cfg-hist-btn',      _t(currentLang, 'settings.histBtn'));
  setCfgText('cfg-skip-fx-label', _t(currentLang, 'settings.skipFxTitle'));

  // ── Legal notice panel ──────────────────────────────────────────────────
  const legalBadgeBtn = document.getElementById('legal-badge-btn') as HTMLElement | null;
  const legalPanel    = document.getElementById('legal-panel')     as HTMLElement | null;
  let legalOpen = false;

  legalBadgeBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    legalOpen = !legalOpen;
    legalPanel?.classList.toggle('hidden', !legalOpen);
    legalPanel?.classList.toggle('flex', legalOpen);
    if (legalBadgeBtn) legalBadgeBtn.style.color = legalOpen ? 'var(--color-cyber-blue, #00e5ff)' : '';
  });
  document.addEventListener('click', (e) => {
    if (legalOpen && !document.getElementById('legal-badge')?.contains(e.target as Node)) {
      legalOpen = false;
      legalPanel?.classList.add('hidden');
      legalPanel?.classList.remove('flex');
      if (legalBadgeBtn) legalBadgeBtn.style.color = '';
    }
  });

  // ── Cookie consent banner ───────────────────────────────────────────────
  const cookieBanner  = document.getElementById('cookie-banner')  as HTMLElement | null;
  const cookieAccept  = document.getElementById('cookie-accept')  as HTMLElement | null;
  const cookieReject  = document.getElementById('cookie-reject')  as HTMLElement | null;
  const COOKIE_KEY    = 'cookie-consent';

  function hideCookieBanner() {
    if (cookieBanner) {
      cookieBanner.style.transition = 'opacity 0.4s ease, transform 0.4s ease';
      cookieBanner.style.opacity = '0';
      cookieBanner.style.transform = 'translateX(-50%) translateY(12px)';
      setTimeout(() => { cookieBanner.style.display = 'none'; }, 420);
    }
  }

  if (!localStorage.getItem(COOKIE_KEY)) {
    // Show after a short delay so it doesn't pop up instantly
    setTimeout(() => {
      if (cookieBanner) {
        cookieBanner.style.opacity = '0';
        cookieBanner.style.transform = 'translateX(-50%) translateY(12px)';
        cookieBanner.style.display = 'flex';
        requestAnimationFrame(() => {
          cookieBanner.style.transition = 'opacity 0.4s ease, transform 0.4s ease';
          cookieBanner.style.opacity = '1';
          cookieBanner.style.transform = 'translateX(-50%) translateY(0)';
        });
      }
    }, 2000);
  }

  cookieAccept?.addEventListener('click', () => {
    localStorage.setItem(COOKIE_KEY, 'accepted');
    hideCookieBanner();
    // Enable GA tracking if previously denied
    (window as any)['ga-disable-G-1PS7MR6MS2'] = false;
  });
  cookieReject?.addEventListener('click', () => {
    localStorage.setItem(COOKIE_KEY, 'rejected');
    hideCookieBanner();
    // Disable GA tracking
    (window as any)['ga-disable-G-1PS7MR6MS2'] = true;
  });

  // Disable GA if previously rejected
  if (localStorage.getItem(COOKIE_KEY) === 'rejected') {
    (window as any)['ga-disable-G-1PS7MR6MS2'] = true;
  }

  // ── Apply legal / cookie strings from central i18n ─────────────────────
  {
    const setTxt = (id: string, txt: string) => { const el = document.getElementById(id); if (el) el.textContent = txt; };
    setTxt('cookie-banner-text',  _t(currentLang, 'cookies.bannerText'));
    setTxt('cookie-accept-label', _t(currentLang, 'cookies.accept'));
    setTxt('cookie-reject-label', _t(currentLang, 'cookies.reject'));
    setTxt('legal-panel-title',   _t(currentLang, 'legal.title'));
    setTxt('legal-badge-label',   _t(currentLang, 'legal.badgeLabel'));
    setTxt('legal-panel-body',    _t(currentLang, 'legal.body'));
    setTxt('legal-cookies-label', _t(currentLang, 'legal.cookiesLabel'));
    setTxt('legal-terms-label',   _t(currentLang, 'legal.termsLabel'));
    setTxt('legal-copy',          _t(currentLang, 'legal.copy'));
  }

  // ── Music player (HTML5 Audio, scene-aware) ──────────────────────────────
  const SCENE_TRACKS: Record<string, { name: string; files: string[] }> = {
    intro:       { name: 'Las píldoras – Inicio',       files: ['/music/1) Death Note - (Ryuk\'s Theme A) Music.mp3'] },
    questions:   { name: 'Las píldoras – Preguntas',    files: ['/music/2) Death Note - (Writing Theme F) Music.mp3', '/music/3) Death Note - (Near\'s Theme C) Music.mp3'] },
    anime:       { name: 'Las píldoras – Anime',        files: ['/music/4) Death Note - (Kira\'s Theme F) Music.mp3'] },
    anime_sad:   { name: 'Las píldoras – Anime Triste', files: ['/music/5) Mirai Nikki Sad music.mp3', '/music/6) Fairy Tail Sad Theme Song.mp3'] },
    anime_drama: { name: 'Las píldoras – Anime Drama',  files: ['/music/7) Fate - Akira Kosemura.mp3'] },
  };

  const DEFAULT_VOLUME = 0.10; // 0–1 range

  // Create one Audio element per scene; cycle files on 'ended' for playlists
  const audioPlayers: Record<string, { audio: HTMLAudioElement; files: string[]; idx: number }> = {};
  Object.entries(SCENE_TRACKS).forEach(([scene, { files }]) => {
    const audio = new Audio(files[0]);
    audio.loop    = files.length === 1;
    audio.volume  = DEFAULT_VOLUME;
    audio.preload = 'auto';
    const state = { audio, files, idx: 0 };
    if (files.length > 1) {
      audio.addEventListener('ended', () => {
        state.idx = (state.idx + 1) % files.length;
        audio.src = files[state.idx];
        audio.volume = getVolume();
        audio.play().catch(() => {});
      });
    }
    audioPlayers[scene] = state;
  });

  let activeScene = 'intro';
  let playing     = false;

  function getVolume(): number {
    const sv = document.getElementById('settings-vol') as HTMLInputElement | null;
    return sv ? parseFloat(sv.value) : DEFAULT_VOLUME;
  }

  const FADE_MS = 1500;

  function fadeVolume(audio: HTMLAudioElement, from: number, to: number, duration: number, onDone?: () => void) {
    const steps    = 30;
    const interval = duration / steps;
    const delta    = (to - from) / steps;
    let step = 0;
    const iv = setInterval(() => {
      step++;
      audio.volume = Math.max(0, Math.min(1, from + delta * step));
      if (step >= steps) { clearInterval(iv); onDone?.(); }
    }, interval);
  }

  function startCurrent() {
    const state = audioPlayers[activeScene];
    if (!state) return;
    state.audio.volume = 0;
    state.audio.play().then(() => {
      fadeVolume(state.audio, 0, getVolume(), FADE_MS);
      playing = true;
    }).catch(() => {});
  }

  function switchTrack(scene: string) {
    if (scene === activeScene) return;
    const prevScene = activeScene;
    const targetVol = getVolume();
    activeScene = scene;
    if (!playing) return;

    // Fade out previous
    const prev = audioPlayers[prevScene];
    if (prev) {
      fadeVolume(prev.audio, targetVol, 0, FADE_MS, () => {
        prev.audio.pause();
        prev.audio.volume = targetVol;
        // Reset playlist index for next time
        prev.idx = 0;
        prev.audio.src = prev.files[0];
      });
    }

    // Fade in new
    const next = audioPlayers[scene];
    if (next) {
      next.audio.currentTime = 0;
      next.audio.volume = 0;
      next.audio.play().then(() => {
        fadeVolume(next.audio, 0, targetVol, FADE_MS);
      }).catch(() => {});
    }
  }

  // La música solo inicia cuando el usuario hace click en el sobre
  window.addEventListener('envelope:opened', () => {
    if (!playing) startCurrent();
  }, { once: true });

  // Scene-based track switching
  window.addEventListener('scene:advance', (e: Event) => {
    if (!playing) return;
    const { to } = (e as CustomEvent).detail;
    if (to === 'questions') {
      switchTrack('questions');
    } else if (to === 'result') {
      if (localStorage.getItem('pillChoice') === 'anime') {
        let answers: Record<string, string> = {};
        try { answers = JSON.parse(localStorage.getItem('userAnswers') || '{}'); } catch {}
        const mood   = answers['mood']   ?? '';
        const genres = answers['genres'] ?? '';
        if (mood === 'melancholic') {
          switchTrack('anime_sad');
        } else if (mood === 'nostalgic' || genres.includes('romance')) {
          switchTrack('anime_drama');
        } else {
          switchTrack('anime');
        }
      }
    } else if (to === 'pills' || to === 'message') {
      switchTrack('intro');
    }
  });



</script>
